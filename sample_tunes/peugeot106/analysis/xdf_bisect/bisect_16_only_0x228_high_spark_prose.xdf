  <XDFHEADER>
    <flags>0x1</flags>
    <fileversion>0.14</fileversion>
    <deftitle>Marelli IAW 8P.40 Peugeot 106 - Comparison Markup</deftitle>
    <description>Reverse-engineering XDF for a 64 KiB 27C512 dump from Marelli IAW 8P.40. This definition is intentionally conservative and marks checksum words, known 68HC11 vector addresses, first-pass candidate regions, and table/vector candidates supported by stock-vs-MOD2 comparison and 68HC11 disassembly. Definitions are raw-byte views unless otherwise noted. Version 0.14 promotes the 21x9 view at 0x802E as the primary likely fuel/VE/air-charge correction candidate, demotes the overlapping 24x9 view to a boundary/debug view, keeps raw display while documenting raw / 2.55 as a visualization hypothesis, and keeps main fuel unconfirmed until a direct injection consumer is found.</description>
    <author>OpenAI Codex</author>
    <baseoffset>0</baseoffset>
    <DEFAULTS datasizeinbits="8" sigdigits="2" outputtype="1" signed="0" lsbfirst="0" float="0" />
    <REGION type="0xFFFFFFFF" startaddress="0x0" size="0x10000" regionflags="0x0" name="Binary File" desc="Full 27C512 image" />
    <CATEGORY index="0x0" name="Notes" />
    <CATEGORY index="0x1" name="68HC11 Vectors" />
    <CATEGORY index="0x2" name="Candidate Calibration Blocks" />
    <CATEGORY index="0x3" name="Raw Block Views" />
    <CATEGORY index="0x4" name="Checksum" />
    <CATEGORY index="0x5" name="MOD2 Compared Candidates" />
