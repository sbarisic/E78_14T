    <CATEGORY index="0x7" name="Code-Confirmed Additional Tables" />
    <CATEGORY index="0x8" name="Diagnostics / Service Data" />
    <CATEGORY index="0x9" name="Public Index Leads" />
    <CATEGORY index="0xA" name="Confirmed" />
  </XDFHEADER>

