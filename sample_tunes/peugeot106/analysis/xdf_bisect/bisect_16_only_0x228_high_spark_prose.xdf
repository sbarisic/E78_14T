  <XDFTABLE uniqueid="0x228" flags="0x30">
    <title>Likely Spark Advance High Octane / Default 24x9 @ 0x8A69</title>
    <description>Single retained view for the code-confirmed Peugeot stock/MOD2 spark bank at 0x8A69. The routine at 0x48EE loads X with 0x8A69 when spark_bank_selector_state RAM 0x20B1 is nonzero, builds a B2D6 descriptor at 0x213A with axis 1 from RAM 0x2034 and axis 2 from RAM 0x2036, sets column count to 9, and accumulates the result into the spark-angle command path around RAM 0x2147. Stock 0x800A=0x00 underflows to runtime 0x20B1=0xFF, so stock behavior selects this bank by default. Values display plausibly as spark advance with X/2 degree scaling, and compared with 0x8B41 this bank generally has more high-load advance, supporting the likely high-octane/default label. X axis is runtime 0x2034, best named MAP/load kPa estimate. X labels are rounded, display-only scaling from 0x2034 raw 0-0x0800 shown as integer 0-100 kPa values because the ECU is MAP referenced and the vehicle uses a 100 kPa PRT03-family MAP sensor; exact ADC transfer remains unproven. Same-family comparison note: RALLY13.ORI carries the stock spark bundle shifted +0x1B, so its high bank is at 0x8A84; Peug.106Rally.org.bin uses this same 0x8A69 offset but has heavily altered cells.</description>
    <CATEGORYMEM index="0" category="10" />
    <XDFAXIS id="x" uniqueid="0x0"><EMBEDDEDDATA mmedelementsizebits="8" mmedmajorstridebits="0" mmedminorstridebits="0" /><indexcount>9</indexcount><datatype>0</datatype><unittype>0</unittype><DALINK index="0" /><LABEL index="0" value="0" /><LABEL index="1" value="13" /><LABEL index="2" value="25" /><LABEL index="3" value="38" /><LABEL index="4" value="50" /><LABEL index="5" value="63" /><LABEL index="6" value="75" /><LABEL index="7" value="88" /><LABEL index="8" value="100" /><MATH equation="X"><VAR id="X" /></MATH></XDFAXIS>
    <XDFAXIS id="y" uniqueid="0x0"><EMBEDDEDDATA mmedelementsizebits="8" mmedmajorstridebits="-32" mmedminorstridebits="0" /><indexcount>24</indexcount><datatype>0</datatype><unittype>0</unittype><DALINK index="0" /><LABEL index="0" value="550" /><LABEL index="1" value="750" /><LABEL index="2" value="850" /><LABEL index="3" value="950" /><LABEL index="4" value="1000" /><LABEL index="5" value="1200" /><LABEL index="6" value="1400" /><LABEL index="7" value="1600" /><LABEL index="8" value="1800" /><LABEL index="9" value="2000" /><LABEL index="10" value="2300" /><LABEL index="11" value="2600" /><LABEL index="12" value="2900" /><LABEL index="13" value="3200" /><LABEL index="14" value="3501" /><LABEL index="15" value="3800" /><LABEL index="16" value="4201" /><LABEL index="17" value="4500" /><LABEL index="18" value="5000" /><LABEL index="19" value="5501" /><LABEL index="20" value="6000" /><LABEL index="21" value="6502" /><LABEL index="22" value="7003" /><LABEL index="23" value="7500" /><MATH equation="X"><VAR id="X" /></MATH></XDFAXIS>
