    <MATH equation="X">
      <VAR id="X" />
    </MATH>
  </XDFCONSTANT>

  <XDFCONSTANT uniqueid="0x115">
    <title>Code-Confirmed Signed Offset Byte @ 0x8A68</title>
    <description>The routine at 0x48EE sign-extends this byte and adds it to the 0x8A69/0x8B41 interpolated result when flag A2 bit 0x02 is set. Stock and MOD2 both store 0x00 here.</description>
    <CATEGORYMEM index="0" category="5" />
    <EMBEDDEDDATA mmedaddress="0x8A68" mmedelementsizebits="8" />
    <units>raw</units>
    <outputtype>1</outputtype>
    <datatype>0</datatype>
    <unittype>0</unittype>
    <DALINK index="0" />
    <MATH equation="X">
      <VAR id="X" />
    </MATH>
  </XDFCONSTANT>

  <XDFCONSTANT uniqueid="0x116">
    <title>Likely RPM Limiter Set Threshold @ 0x879E</title>
    <description>Code at 0x6F28 compares period-like RAM 0x00BA against this word when RAM 0x214F is zero and sets RAM 0x00A4 bit 0x10 if the period is below the threshold. Displayed as RPM using the locally code/axis-supported 15000000 / period. Stock 0x07EB is about 7400 RPM; MOD2 0x00FA is about 60000 RPM. A public forum lead mentions 21000000 / value for an IAW8P40 limiter, but that formula is not adopted here because it does not match the local 0x929E axis math.</description>
    <CATEGORYMEM index="0" category="6" />
    <EMBEDDEDDATA mmedaddress="0x879E" mmedelementsizebits="16" />
    <units>rpm</units>
    <outputtype>1</outputtype>
    <datatype>0</datatype>
    <unittype>0</unittype>
    <DALINK index="0" />
    <MATH equation="15000000 / X"><VAR id="X" /></MATH>
  </XDFCONSTANT>

  <XDFCONSTANT uniqueid="0x117">
    <title>Likely RPM Limiter Clear Threshold @ 0x87A0</title>
    <description>Code at 0x6F12 compares period-like RAM 0x00BA against this word when RAM 0x214F is zero and clears RAM 0x00A4 bit 0x10 when the period rises above the threshold. Displayed as RPM using the locally code/axis-supported 15000000 / period. Stock 0x07EF is about 7386 RPM; MOD2 0xFFFF is about 229 RPM. A public forum lead mentions 21000000 / value for an IAW8P40 limiter, but that formula is not adopted here because it does not match the local 0x929E axis math.</description>
    <CATEGORYMEM index="0" category="6" />
    <EMBEDDEDDATA mmedaddress="0x87A0" mmedelementsizebits="16" />
    <units>rpm</units>
    <outputtype>1</outputtype>
    <datatype>0</datatype>
    <unittype>0</unittype>
    <DALINK index="0" />
    <MATH equation="15000000 / X"><VAR id="X" /></MATH>
  </XDFCONSTANT>

  <XDFCONSTANT uniqueid="0x118">
    <title>Alternate RPM Threshold Set @ 0x87A2</title>
    <description>Code at 0x6F24 uses this period threshold instead of 0x879E when RAM 0x214F is nonzero. Displayed as RPM using 15000000 / period. Stock 0x1770 is about 2500 RPM.</description>
    <CATEGORYMEM index="0" category="6" />
    <EMBEDDEDDATA mmedaddress="0x87A2" mmedelementsizebits="16" />
    <units>rpm</units>
    <outputtype>1</outputtype>
    <datatype>0</datatype>
    <unittype>0</unittype>
    <DALINK index="0" />
    <MATH equation="15000000 / X"><VAR id="X" /></MATH>
  </XDFCONSTANT>

  <XDFCONSTANT uniqueid="0x119">
    <title>Alternate RPM Threshold Clear @ 0x87A4</title>
    <description>Code at 0x6F0E uses this period threshold instead of 0x87A0 when RAM 0x214F is nonzero. Displayed as RPM using 15000000 / period. Stock 0x1979 is about 2300 RPM.</description>
    <CATEGORYMEM index="0" category="6" />
    <EMBEDDEDDATA mmedaddress="0x87A4" mmedelementsizebits="16" />
    <units>rpm</units>
    <outputtype>1</outputtype>
    <datatype>0</datatype>
    <unittype>0</unittype>
    <DALINK index="0" />
    <MATH equation="15000000 / X"><VAR id="X" /></MATH>
  </XDFCONSTANT>

  <XDFCONSTANT uniqueid="0x11A">
    <title>Spark Bank Selector Config @ 0x800A</title>
    <description>Calibration byte loaded around 0xCBEF and decremented before storage to RAM 0x20B1. Runtime 0x20B1 selects the likely spark bank: nonzero selects 0x8A69, zero selects 0x8B41. Stock value is 0x00, which underflows to 0xFF after decrement, so stock runtime behavior selects the 0x8A69 bank.</description>
    <CATEGORYMEM index="0" category="6" />
    <EMBEDDEDDATA mmedaddress="0x800A" mmedelementsizebits="8" />
    <units>raw</units>
    <outputtype>1</outputtype>
    <datatype>0</datatype>
    <unittype>0</unittype>
    <DALINK index="0" />
    <MATH equation="X"><VAR id="X" /></MATH>
  </XDFCONSTANT>

