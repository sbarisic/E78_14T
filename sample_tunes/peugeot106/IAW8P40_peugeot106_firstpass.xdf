    <MATH equation="X">
      <VAR id="X" />
    </MATH>
  </XDFCONSTANT>

  <XDFCONSTANT uniqueid="0x116">
    <title>Primary RPM Limiter Set Threshold @ 0x879E</title>
    <description>Code at 0x6F28 compares period-like RAM 0x00BA against this word when RAM 0x214F is zero and sets RAM 0x00A4 bit 0x10 if the period is below the threshold. Displayed as RPM using the locally code/axis-supported 15000000 / period. Stock 0x07EB is about 7400 RPM; MOD2 0x00FA is about 60000 RPM. A public forum lead mentions 21000000 / value for an IAW8P40 limiter, but that formula is not adopted here because it does not match the local 0x929E axis math.</description>
    <CATEGORYMEM index="0" category="7" />
    <EMBEDDEDDATA mmedaddress="0x879E" mmedelementsizebits="16" />
    <units>rpm</units>
    <outputtype>1</outputtype>
    <datatype>0</datatype>
    <unittype>0</unittype>
    <DALINK index="0" />
    <MATH equation="15000000 / X"><VAR id="X" /></MATH>
  </XDFCONSTANT>

  <XDFCONSTANT uniqueid="0x117">
    <title>Primary RPM Limiter Clear Threshold @ 0x87A0</title>
    <description>Code at 0x6F12 compares period-like RAM 0x00BA against this word when RAM 0x214F is zero and clears RAM 0x00A4 bit 0x10 when the period rises above the threshold. Displayed as RPM using the locally code/axis-supported 15000000 / period. Stock 0x07EF is about 7386 RPM; MOD2 0xFFFF is about 229 RPM. A public forum lead mentions 21000000 / value for an IAW8P40 limiter, but that formula is not adopted here because it does not match the local 0x929E axis math.</description>
    <CATEGORYMEM index="0" category="7" />
    <EMBEDDEDDATA mmedaddress="0x87A0" mmedelementsizebits="16" />
    <units>rpm</units>
    <outputtype>1</outputtype>
    <datatype>0</datatype>
    <unittype>0</unittype>
    <DALINK index="0" />
    <MATH equation="15000000 / X"><VAR id="X" /></MATH>
  </XDFCONSTANT>

  <XDFCONSTANT uniqueid="0x118">
    <title>Alternate RPM Limiter Set Threshold @ 0x87A2</title>
    <description>Code at 0x6F24 uses this period threshold instead of 0x879E when RAM 0x214F is nonzero. Displayed as RPM using 15000000 / period. Stock 0x1770 is about 2500 RPM.</description>
    <CATEGORYMEM index="0" category="7" />
    <EMBEDDEDDATA mmedaddress="0x87A2" mmedelementsizebits="16" />
