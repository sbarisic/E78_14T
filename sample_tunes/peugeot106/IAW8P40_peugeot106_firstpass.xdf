  <XDFTABLE uniqueid="0x26F" flags="0x30">
    <title>Fuel Output Edge Offset / Deadline vs $00CC Surplus $2040 1x9 @ 0x8789</title>
    <description>Raw 16-bit timer-tick view used by helper B26E to build $2086 from internal $2040, where $2040 = max($00CC - 0x8000, 0) >> 4. X labels are decimal $00CC display values for 0x8000, 0x9000, 0xA000, 0xB000, 0xC000, 0xD000, 0xE000, 0xF000, and 0xFFFF/end. Provisional edge-offset/deadline support for the fuel output scheduler; this is not fuel quantity and not normal injector battery deadtime. 0x879B and 0x879C are separate data, not part of this table.</description>
    <CATEGORYMEM index="0" category="13" />
    <XDFAXIS id="x" uniqueid="0x0"><EMBEDDEDDATA mmedelementsizebits="8" mmedmajorstridebits="0" mmedminorstridebits="0" /><indexcount>9</indexcount><datatype>0</datatype><unittype>0</unittype><DALINK index="0" /><LABEL index="0" value="32768" /><LABEL index="1" value="36864" /><LABEL index="2" value="40960" /><LABEL index="3" value="45056" /><LABEL index="4" value="49152" /><LABEL index="5" value="53248" /><LABEL index="6" value="57344" /><LABEL index="7" value="61440" /><LABEL index="8" value="65535" /><MATH equation="X"><VAR id="X" /></MATH></XDFAXIS>
    <XDFAXIS id="y" uniqueid="0x0"><EMBEDDEDDATA mmedelementsizebits="8" mmedmajorstridebits="-32" mmedminorstridebits="0" /><indexcount>1</indexcount><datatype>0</datatype><unittype>0</unittype><DALINK index="0" /><LABEL index="0" value="raw" /><MATH equation="X"><VAR id="X" /></MATH></XDFAXIS>
    <XDFAXIS id="z"><EMBEDDEDDATA mmedaddress="0x8789" mmedelementsizebits="16" mmedrowcount="1" mmedcolcount="9" mmedmajorstridebits="0" mmedminorstridebits="0" /><decimalpl>0</decimalpl><min>0.000000</min><max>65535.000000</max><outputtype>1</outputtype><MATH equation="X"><VAR id="X" /></MATH></XDFAXIS>
  </XDFTABLE>

  <XDFTABLE uniqueid="0x2AA" flags="0x30">
    <title>Fuel Output Edge Offset / Deadline ms 2us Assumption 1x9 @ 0x8789</title>
    <description>Provisional millisecond display for the 0x8789 fuel-output edge-offset/deadline table. Assumes 2 us/tick, so ms = raw ticks * 0.002. X labels are decimal $00CC display values for 0x8000, 0x9000, 0xA000, 0xB000, 0xC000, 0xD000, 0xE000, 0xF000, and 0xFFFF/end. Raw timer ticks remain authoritative until E-clock and timer prescaler are confirmed; this is scheduler timing support, not fuel quantity and not normal injector battery deadtime.</description>
    <CATEGORYMEM index="0" category="13" />
    <XDFAXIS id="x" uniqueid="0x0"><EMBEDDEDDATA mmedelementsizebits="8" mmedmajorstridebits="0" mmedminorstridebits="0" /><indexcount>9</indexcount><datatype>0</datatype><unittype>0</unittype><DALINK index="0" /><LABEL index="0" value="32768" /><LABEL index="1" value="36864" /><LABEL index="2" value="40960" /><LABEL index="3" value="45056" /><LABEL index="4" value="49152" /><LABEL index="5" value="53248" /><LABEL index="6" value="57344" /><LABEL index="7" value="61440" /><LABEL index="8" value="65535" /><MATH equation="X"><VAR id="X" /></MATH></XDFAXIS>
