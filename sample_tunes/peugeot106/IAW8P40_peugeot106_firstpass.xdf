  <XDFCONSTANT uniqueid="0x115">
    <title>Code-Confirmed Signed Offset Byte @ 0x8A68</title>
    <description>The routine at 0x48EE sign-extends this byte and adds it to the 0x8A69/0x8B41 interpolated result when flag A2 bit 0x02 is set. Stock and MOD2 both store 0x00 here.</description>
    <CATEGORYMEM index="0" category="5" />
    <EMBEDDEDDATA mmedaddress="0x8A68" mmedelementsizebits="8" />
    <units>raw</units>
