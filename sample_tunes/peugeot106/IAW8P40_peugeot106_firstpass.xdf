  <XDFTABLE uniqueid="0x292" flags="0x30">
    <title>Fuel Scheduler Signed Correction vs $00CC Surplus $2040 1x10 @ 0x9303</title>
    <description>DHC11 0xD6F5-0xD6FF indexes this signed byte scheduler correction/coefficient with $2040, where $2040 = max($00CC - 0x8000, 0) >> 4, through helper 0xB2BA and stores $2048. It begins immediately after the separate 1x9 table at 0x92FA and is exposed separately because the code uses 0x9303 as an exact base. X labels 32768 through 65535 are decimal $00CC display values for 0x8000 through 0xFFFF/end; the final 65536 label is a numeric-only display sentinel for the guard/unproven cell and is not a real 16-bit $00CC value. Keep signed raw.</description>
    <CATEGORYMEM index="0" category="13" />
    <XDFAXIS id="x" uniqueid="0x0"><EMBEDDEDDATA mmedelementsizebits="8" mmedmajorstridebits="0" mmedminorstridebits="0" /><indexcount>10</indexcount><datatype>0</datatype><unittype>0</unittype><DALINK index="0" /><LABEL index="0" value="32768" /><LABEL index="1" value="36864" /><LABEL index="2" value="40960" /><LABEL index="3" value="45056" /><LABEL index="4" value="49152" /><LABEL index="5" value="53248" /><LABEL index="6" value="57344" /><LABEL index="7" value="61440" /><LABEL index="8" value="65535" /><LABEL index="9" value="65536" /><MATH equation="X"><VAR id="X" /></MATH></XDFAXIS>
    <XDFAXIS id="y" uniqueid="0x0"><EMBEDDEDDATA mmedelementsizebits="8" mmedmajorstridebits="-32" mmedminorstridebits="0" /><indexcount>1</indexcount><datatype>0</datatype><unittype>0</unittype><DALINK index="0" /><LABEL index="0" value="signed raw" /><MATH equation="X"><VAR id="X" /></MATH></XDFAXIS>
    <XDFAXIS id="z"><EMBEDDEDDATA mmedtypeflags="0x01" mmedaddress="0x9303" mmedelementsizebits="8" mmedrowcount="1" mmedcolcount="10" mmedmajorstridebits="0" mmedminorstridebits="0" /><decimalpl>0</decimalpl><min>-128.000000</min><max>127.000000</max><outputtype>1</outputtype><MATH equation="X"><VAR id="X" /></MATH></XDFAXIS>
