  <XDFCONSTANT uniqueid="0x11A">
    <title>Spark Bank Selector Config @ 0x800A</title>
    <description>Calibration byte loaded around 0xCBEF and decremented before storage to RAM 0x20B1. Runtime 0x20B1 selects the likely spark bank: nonzero selects 0x8A69, zero selects 0x8B41. Stock value is 0x00, which underflows to 0xFF after decrement, so stock runtime behavior selects the 0x8A69 bank.</description>
    <CATEGORYMEM index="0" category="7" />
    <EMBEDDEDDATA mmedaddress="0x800A" mmedelementsizebits="8" />
    <units>raw</units>
    <outputtype>1</outputtype>
    <datatype>0</datatype>
    <unittype>0</unittype>
    <DALINK index="0" />
    <MATH equation="X"><VAR id="X" /></MATH>
  </XDFCONSTANT>































