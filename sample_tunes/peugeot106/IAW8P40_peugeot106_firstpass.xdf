    <XDFAXIS id="z"><EMBEDDEDDATA mmedaddress="0x8789" mmedelementsizebits="16" mmedrowcount="1" mmedcolcount="9" mmedmajorstridebits="0" mmedminorstridebits="0" /><decimalpl>3</decimalpl><min>0.000000</min><max>131.070000</max><outputtype>1</outputtype><MATH equation="X * 0.002"><VAR id="X" /></MATH></XDFAXIS>
